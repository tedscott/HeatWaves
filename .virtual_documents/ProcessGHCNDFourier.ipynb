         label="Slope = "+str(slope)+" $\pm$ "+str(slope_sd)+" $R^2$ = "+str(r_squared))
    ax1.plot(x, mk_trend, linestyle="dashed", linewidth=lw, color='blue', label="MK Slope = "+str(np.round(res_mk.slope,3)))
