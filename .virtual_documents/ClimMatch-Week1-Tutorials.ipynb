# func for Planck's law that returns intensity and peak lambda from Wien's law
def planck(wavelength, temperature):
    intensity = (2*h*c**2)/(wavelength**5) * 1/(np.exp(h*c/(wavelength*k*temperature)) - 1)
    lpeak = 2.898e-3/temperature
    return intensity, lpeak

