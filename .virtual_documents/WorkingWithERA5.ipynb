# interactive plot of hourly frequency of surface temperature
# this cell may take a little longer as it contains several maps in a single plotting function
ds_surface_temp_2m_hour = ds_surface_temp_2m.groupby("time.hour").mean()
dataset_plot = gvDataset(
    ds_surface_temp_2m_hour.isel(hour=slice(0, 23))
)  # only the first 12 time steps, as it is a time consuming task
images = dataset_plot.to(
    gvImage, ["longitude", "latitude"], ["t2m"], "hour"
)
images.opts(
    cmap="coolwarm",
    colorbar=True,
    width=600,
    height=400,
    projection=ccrs.PlateCarree(),
    clabel="2m Air Temperature [K]",
) * gf.coastline


#ds_surface_temp_2m_hour





# can weight these cells use cos(lat) because it is a regular grid
# need to look up or ask what this is saying - kinda get it but just to be sure!

weights = np.cos(np.deg2rad(ds_surface_temp_2m.latitude))
weights.name = "weights" # not sure why we did this since we aren't merging with the dataset but OK

# get weighted spatial mean
ds_surface_temp_2m_ts = ds_surface_temp_2m.weighted(weights).mean(["longitude","latitude"])
ds_surface_temp_2m_ts                                             


# create a 3 day moving average?
t2m_3day_avg = ds_surface_temp_2m_ts.rolling(time=24*3, center=True).mean()

#oni_index = tos_nino34_anom_mean.rolling(time=3, center=True).mean() # ONI stands for Ocean El Nino Index

# now plot timeseries
fig,ax = plt.subplots(1,1, figsize=(10,3))
ax.plot(ds_surface_temp_2m_ts.time, ds_surface_temp_2m_ts, label="Mean Hourly (weighted cos(lat))")
ax.plot(t2m_3day_avg.time, t2m_3day_avg, label="3-day avg")
ax.set_ylabel("2m Air Temp (K)")
ax.xaxis.set_tick_params(rotation=45)
plt.suptitle("Hourly T2m Puget Sound - June 2021")
#plt.title("weighted mean based on cosine of latitude", y=-0.5)
ax.legend()








# create useful copy of data of daily max values of temp per grid cell
t2m_daily_max = dset_daily

# from https://stackoverflow.com/questions/73703299/how-to-extract-percentile-values-using-xarray
# this is the 90th percentile value of max temp for each cell over the time (June 2021)
c_90 = t2m_daily_max.t2m.where(t2m_daily_max.t2m != 0).quantile(0.90, dim=('time'))
c_90



t2m_daily_max


# plot for upper left cell the daily max temps and the 90th percentile
plot_data = t2m_daily_max.t2m.isel(latitude=0,longitude=0)
plot_c_90 = c_90.isel(latitude=0,longitude=0)
plt.figure(figsize=(8,4))
plt.plot(plot_data.time, plot_data.data)
plt.fill_between(  # plot with color in between
    plot_data.time,  # x values
    # top boundary - y values above 0.5
    plot_data.data,
    plot_c_90,  # bottom boundary - 0.5
    where=(plot_data >= plot_c_90),
    color="red",  # color
    alpha=0.9,  # transparency value
    interpolate=True
)
plt.axhline(plot_c_90, color="black", linewidth=0.5, linestyle="dashed")
plt.tick_params(axis='x',rotation=45)
plt.ylim([280,315])
plt.title("Max daily temps for Lat,Lon = [50,-124] and above 90th Percentile dates")
plt.xlabel("Date")
plt.ylabel("Max Daily Temp (K)")



# plot for another warmer interior cell the daily max temps and the 90th percentile
