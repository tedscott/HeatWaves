# loop through all plot variables
for i,v in enumerate(plot_vars):


    # variables for plot
    x = df_summ.Year
    y = df_summ[v]
    
    # get linear fit and plot it with data
    coefs, V = np.polyfit(x, y, 1, cov=True)
